# ClubCMS — .env per clubs.betabi.it (aaPanel)
# Copiare in: /www/wwwroot/clubs.betabi.it/clubcms/.env
# NON committare il file .env reale nel repository!
#
# DB: PostgreSQL gestito da aaPanel — utente/db: YOUR_DB_NAME
# Il container raggiunge il DB del host tramite host.docker.internal

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-questa-chiave-con-una-stringa-random-di-50-caratteri
DJANGO_SETTINGS_MODULE=clubcms.settings.prod
DEBUG=False

ALLOWED_HOSTS=clubs.betabi.it,www.clubs.betabi.it
CSRF_TRUSTED_ORIGINS=https://clubs.betabi.it,https://www.clubs.betabi.it

# ── Database (PostgreSQL aaPanel — utente/db: YOUR_DB_NAME, porta 5432) ───────
# Il container Django raggiunge il PostgreSQL del host tramite host.docker.internal
# Sostituisci PASSWORD_DB con la password scelta in aaPanel → Database → PostgreSQL
DATABASE_URL=postgres://YOUR_DB_NAME:PASSWORD_DB@host.docker.internal:5432/YOUR_DB_NAME

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@clubs.betabi.it
EMAIL_PASSWORD=password-smtp
DEFAULT_FROM_EMAIL=ClubCMS <noreply@clubs.betabi.it>

# ── Wagtail ──────────────────────────────────────────────────────────────────
WAGTAIL_SITE_NAME=ClubsCMS

# ── Django Q (task queue) ────────────────────────────────────────────────────
# q_cluster usa lo stesso DATABASE_URL sopra

# ── Media / Static ───────────────────────────────────────────────────────────
# I path fisici sono montati come bind mount (vedi docker-compose.yml):
#   staticfiles → /www/wwwroot/clubs.betabi.it/staticfiles/
#   media       → /www/wwwroot/clubs.betabi.it/media/
