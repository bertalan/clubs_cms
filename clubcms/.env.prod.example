# ClubCMS — Production environment variables
# Copy to .env and fill in values before running docker-compose.prod.yml

# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_SETTINGS_MODULE=clubcms.settings.prod
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database
POSTGRES_DB=clubcms
POSTGRES_USER=clubcms
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://clubcms:change-me@db:5432/clubcms

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASSWORD=change-me
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Wagtail
WAGTAILADMIN_BASE_URL=https://yourdomain.com

# Federation (optional)
FEDERATION_ENABLED=false
FEDERATION_OUR_CLUB_CODE=
FEDERATION_OUR_CLUB_NAME=

# Push Notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=

# SSL domain (for nginx)
DOMAIN=yourdomain.com
